	<subDataset name="Dataset_detail" uuid="9d712ef0-7387-49e9-aba9-76c1b17ffed1">
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Dione.jrdax"/>
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<parameter name="id" class="java.lang.String"/>
		<parameter name="startDate" class="java.lang.String"/>
		<parameter name="endDate" class="java.lang.String"/>
		<queryString>
			<![CDATA[SELECT q.name, q.unitPrice, SUM(q.qty) AS qty, (q.unitPrice * SUM(q.qty)) AS total
FROM (
                    SELECT od.id, et.id AS eventTypeId, od.pricingId, CONCAT(et.name, ' ', pt.name) AS name, pc.price AS unitPrice, 1 AS qty
                    FROM action_membership.orders o
                    JOIN action_membership.event e ON o.eventId = e.id
                    JOIN action_membership.orderDetail od ON od.orderId = o.id
                    JOIN action_membership.eventType et ON od.eventTypeId = et.id
                    JOIN action_membership.pricing pc ON od.pricingId = pc.id
                    JOIN action_membership.paymentType pt ON pc.paymentTypeId = pt.id
                    WHERE e.uuid =  $P{id} 
                    AND o.createdTime BETWEEN $P{startDate} AND $P{endDate} 
                    AND o.paymentStatus = 'SUCCESS'
                    UNION
                    SELECT od.id, et.id AS eventTypeId, od.pricingId, et.name AS name, od.price AS unitPrice, 1 AS qty
                    FROM action_membership.orders o
                    JOIN action_membership.event e ON o.eventId = e.id
                    JOIN action_membership.orderDetail od ON od.orderId = o.id AND od.pricingId IS NULL
                    JOIN action_membership.eventType et ON od.eventTypeId = et.id
                    WHERE e.uuid =  $P{id} 
                    AND o.createdTime BETWEEN $P{startDate} AND $P{endDate} 
                    AND o.paymentStatus = 'SUCCESS'
 ) AS q
 GROUP BY q.eventTypeId, q.pricingId, q.unitPrice
 ORDER BY q.eventTypeId, q.pricingId]]>
		</queryString>
		<field name="name" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="name"/>
			<property name="com.jaspersoft.studio.field.label" value="name"/>
		</field>
		<field name="unitPrice" class="java.lang.Double">
			<property name="com.jaspersoft.studio.field.name" value="unitPrice"/>
			<property name="com.jaspersoft.studio.field.label" value="unitPrice"/>
		</field>
		<field name="qty" class="java.math.BigDecimal">
			<property name="com.jaspersoft.studio.field.name" value="qty"/>
			<property name="com.jaspersoft.studio.field.label" value="qty"/>
		</field>
		<field name="total" class="java.lang.Double">
			<property name="com.jaspersoft.studio.field.name" value="total"/>
			<property name="com.jaspersoft.studio.field.label" value="total"/>
		</field>
	</subDataset>
	<parameter name="signatureUrl" class="java.lang.String"/>
	<parameter name="sealUrl" class="java.lang.String"/>
	<parameter name="id" class="java.lang.String"/>
	<parameter name="startDate" class="java.lang.String"/>
	<parameter name="endDate" class="java.lang.String"/>
	<parameter name="remark" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT e.uuid, e.name AS eventName, c.runNo AS contractNo, 
		SUM(o.unitPrice) AS totalAmount,
        SUM(o.couponDiscount) AS totalDiscountCoupon, 
        SUM(o.discountShirt) AS totalDiscountShirt, 
        SUM(o.shippingFee) AS totalShippingFee,
        SUM(o.totalPrice) AS totalNetAmount
FROM action_membership.orders o
JOIN action_membership.event e ON o.eventId = e.id
JOIN action_membership.contract c ON c.eventId = e.id
WHERE e.uuid =  $P{id} 
  AND o.createdTime BETWEEN  $P{startDate}  AND  $P{endDate} 
  AND o.paymentStatus = 'SUCCESS']]>
	</queryString>
