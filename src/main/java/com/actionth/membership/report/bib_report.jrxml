	<parameter name="qrUrl" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT od.uuid, od.bibNo, ss.name AS shirtSize, et.name AS eventTypeName, 
	DATE_FORMAT(
        DATE_SUB(et.eventDate, INTERVAL 1 DAY),
        '%d-%m-%Y | 08:00-17:00'
    ) AS eventDate, 
    e.name AS eventName, od.idNo, 
	CONCAT(od.firstName, IFNULL(CONCAT(' ', od.lastName), '')) AS runner
FROM action_membership.orderDetail od
JOIN action_membership.eventType et ON et.id = od.eventTypeId
JOIN action_membership.event e ON e.id = et.eventId
LEFT JOIN action_membership.shirtSize ss ON ss.id = od.shirtSizeId
WHERE od.uuid =  $P{participantUuid}]]>
	</queryString>
