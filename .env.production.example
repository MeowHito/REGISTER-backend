# =============================================================================
# Production environment variables for the membership backend.
#
# Usage (Docker):
#   cp .env.production.example .env.production   # fill in REAL values
#   docker build -t membership-be .
#   docker run --env-file .env.production -p 8080:8080 membership-be
#
# The real .env.production is gitignored — never commit it.
# Values marked <FILL> have no safe default and MUST be set.
# =============================================================================

# --- App / environment -------------------------------------------------------
APP_ENV=PROD                              # MUST be PROD in production:
                                          #  - enables real email sending (non-PROD blocks all email)
                                          #  - sets Secure cookies (requires HTTPS)
APP_FE_URL=https://your-frontend-domain   # <FILL> real frontend URL (no trailing slash)
APP_BE_URL=https://your-backend-domain    # <FILL> real backend URL
APP_CONTACT_EMAIL=admin@yourdomain.com    # <FILL> receives contact/announcement mail
SEED_USER_PASSWORD=<FILL>                 # password for the auto-seeded admin users (first deploy)
# APP_EMAIL_LOGO_URL=                      # optional, defaults to ${APP_FE_URL}/assets/images/logoB.png
# APP_REPORT_PATH=/com/actionth/membership/report   # optional

# --- Security secrets (use the generated random values) ----------------------
JWT_SECRET_KEY=<FILL>                     # long random string (openssl rand -base64 48)
PARTICIPANT_TOKEN_SECRET=<FILL>           # long random string (different from JWT)

# --- Database (MySQL) --------------------------------------------------------
# First deploy on an EMPTY db: load db/schema-prod.sql, then keep DDL_AUTO=none.
DB_URL=jdbc:mysql://DB_HOST:3306/membership_db?useSSL=true&allowPublicKeyRetrieval=true&serverTimezone=Asia/Bangkok  # <FILL> host
DB_USER=<FILL>
DB_PASSWORD=<FILL>
JPA_DDL_AUTO=none                         # none/validate in prod. NEVER create/update (data loss)

# --- Mail (SMTP) -------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=xoasitz@gmail.com                          # full email address
SMTP_PASSWORD=Xoasitz2005                      # Gmail App Password (16 chars) or SMTP password
# EMAIL_TEST_ALLOWLIST=                     # leave empty in PROD; in non-PROD this allowlists test recipients
# APP_EMAIL_DAILY_LIMIT=500
# EMAIL_QUEUE_DAILY_LIMIT=50

# --- Redis -------------------------------------------------------------------
REDIS_HOST=<FILL>
REDIS_PORT=6379
REDIS_PASSWORD=<FILL>                     # set a real password in prod

# --- RabbitMQ ----------------------------------------------------------------
RMQ_HOST=<FILL>
RMQ_PORT=5672
RMQ_USER=<FILL>
RMQ_PASSWORD=<FILL>
# RMQ_QUEUE_EMAIL=emailQueue
# RMQ_QUEUE_SIMPLE_EMAIL=simpleEmailQueue

# --- AWS S3 (file storage) ---------------------------------------------------
# NOTE: region is hardcoded to ap-southeast-1 (Singapore) in code — create the bucket there.
AWS_S3_ACCESS_KEY=<FILL>
AWS_S3_SECRET_KEY=<FILL>
AWS_S3_BUCKET_NAME=<FILL>
AWS_S3_ROOT_PATH=action_membership/

# --- OAuth login -------------------------------------------------------------
AUTH_GOOGLE_CLIENT_ID=<FILL>
AUTH_GOOGLE_CLIENT_SECRET=<FILL>
AUTH_GOOGLE_REDIRECT_URL=https://your-frontend-domain/auth/google/callback   # <FILL> must match Google console
AUTH_FB_CLIENT_ID=<FILL>
AUTH_FB_CLIENT_SECRET=<FILL>
AUTH_LINE_CLIENT_ID=<FILL>                # LINE Login Channel ID
AUTH_LINE_CLIENT_SECRET=<FILL>            # LINE Login Channel secret

# --- Payment: SCB ------------------------------------------------------------
SCB_APP_KEY=<FILL>
SCB_APP_SECRET=<FILL>
SCB_BASE_URL=https://api.partners.scb     # <FILL> production URL (not sandbox)
SCB_COMPANY_ID=<FILL>
SCB_TERMINAL_ID=<FILL>
SCB_PP_ID=<FILL>                          # merchant PromptPay id
SCB_REF3=SCB

# --- Payment: 2C2P -----------------------------------------------------------
MERCHANT_ID_2C2P=<FILL>
MERCHANT_ID_2C2P_EWALLET=<FILL>
PAYMENT_KEY_2C2P=<FILL>
INQUIRY_URL_2C2P=https://pgw.2c2p.com/payment/4.1/paymentInquiry   # production (not sandbox-pgw)
TOKEN_URL_2C2P=https://pgw.2c2p.com/payment/4.1/paymentToken

# --- Misc --------------------------------------------------------------------
SWAGGER_ENABLED=false                     # keep false in prod
# MAX_FILE_SIZE=20MB
# MAX_REQUEST_SIZE=20MB
